**/*.pyo
**/*.pyd
**/db.sqlite3
**/obj/
**/bin/

# --- Node.js / Frontend ---
Front/node_modules/
Front/dist/
Front/dist-ssr/
Front/*.local
node_modules/

# --- Arquivos Sensíveis (CRÍTICO) ---
.env
.env.*
backend/.env
backend/ .env
backend/.env.*
Front/.env
Front/.env.*

# --- Banco de Dados / Temporários ---
backend/*.sqlite3
backend/*.db
logs/
*.log
npm-debug.log*
yarn-debug.log*

# --- Editores ---
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
